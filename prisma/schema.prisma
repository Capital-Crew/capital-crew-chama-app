}

model SystemAccountingMapping {
  id        String            @id @default(uuid())
  type      SystemAccountType @unique
  accountId String

  account LedgerAccount @relation(fields: [accountId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

model ProductAccountingMapping {
  id        String      @id @default(uuid())
  productId String
  product   LoanProduct @relation(fields: [productId], references: [id])

  accountId   String
  account     LedgerAccount         @relation(fields: [accountId], references: [id])
  accountType ProductAccountingType

  @@unique([productId, accountType])
  @@index([productId])
  @@index([accountId])
}

// ========================================
// STRICT LOAN LEDGER
// ========================================

enum LoanTransactionType {
  DISBURSEMENT
  REPAYMENT
  INTEREST
  PENALTY
  WAIVER
  REVERSAL
}

model LoanTransaction {
  id     String @id @default(cuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id])
  runId  String?
  run    InterestEngineRun? @relation(fields: [runId], references: [id])

  type   LoanTransactionType
  amount Decimal             @db.Decimal(15, 2)

  description String?
  referenceId String? // External Ref (e.g. JE Number)

  isReversed Boolean @default(false)

  // Specific Allocation (Bucket-Based Ledger)
  principalAmount    Decimal @default(0) @db.Decimal(15, 2)
  interestAmount     Decimal @default(0) @db.Decimal(15, 2)
  penaltyAmount      Decimal @default(0) @db.Decimal(15, 2)
  feeAmount          Decimal @default(0) @db.Decimal(15, 2)
  overpaymentPortion Decimal @default(0) @db.Decimal(15, 2)

  postedAt        DateTime  @default(now())
  transactionDate DateTime  @default(now()) // Added for strict date tracking
  reversedAt      DateTime? // Added for reversal tracking

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([loanId, isReversed])
  @@index([createdAt])
  @@index([postedAt])
  @@index([transactionDate])
}

model DailySummary {
  id   String   @id @default(cuid())
  date DateTime @unique

  // Portfolio Snapshots
  totalPrincipalOutstanding Decimal @db.Decimal(19, 4)
  totalInterestReceivable   Decimal @db.Decimal(19, 4)
  totalPenaltyReceivable    Decimal @db.Decimal(19, 4)

  // Performance
  disbursementVolume Decimal @db.Decimal(19, 4)
  repaymentVolume    Decimal @db.Decimal(19, 4)

  createdAt DateTime @default(now())
}

model ReportingMapping {
  id          String @id @default(cuid())
  reportLine  String // e.g. "INTEREST_INCOME", "OFFICE_EXPENSE"
  accountCode String // Link to LedgerAccount.code

  @@unique([reportLine, accountCode])
}

model RepaymentInstallment {
  id     String @id @default(cuid())
  loanId String
  loan   Loan   @relation("LoanRepaymentInstallments", fields: [loanId], references: [id], onDelete: Cascade)

  installmentNumber Int
  dueDate           DateTime

  // Scheduled Amounts
  principalDue Decimal @db.Decimal(15, 2)
  interestDue  Decimal @db.Decimal(15, 2)
  penaltyDue   Decimal @default(0) @db.Decimal(15, 2) // Contingent, starts at 0
  feeDue       Decimal @default(0) @db.Decimal(15, 2) // Contingent, starts at 0

  // Paid Amounts (Mutable State)
  principalPaid Decimal @default(0) @db.Decimal(15, 2)
  interestPaid  Decimal @default(0) @db.Decimal(15, 2)
  penaltyPaid   Decimal @default(0) @db.Decimal(15, 2)
  feesPaid      Decimal @default(0) @db.Decimal(15, 2)

  isFullyPaid Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([loanId, installmentNumber])
  @@index([loanId])
  @@index([dueDate])
}

// ========================================
// AUTHENTICATION MODELS
// ========================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

// ========================================
// CONTRIBUTIONS WATERFALL MODULE
// ========================================

enum MonthlyTrackerStatus {
  PAID
  PARTIAL
  PENDING
  OVERDUE
}

model MonthlyTracker {
  id       String @id @default(cuid())
  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  month DateTime // The first day of the month being tracked
  year  Int

  required Decimal @db.Decimal(19, 4) // Snapshot of expected amount
  paid     Decimal @default(0) @db.Decimal(19, 4)
  balance  Decimal @db.Decimal(19, 4) // Computed: required - paid

  status MonthlyTrackerStatus @default(PENDING)

  isPenalized    Boolean @default(false)
  penaltyApplied Decimal @default(0) @db.Decimal(19, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, month, year]) // One tracker per month per member
  @@index([memberId])
  @@index([status])
}

model ContributionProduct {
  id                String         @id @default(cuid())
  name              String
  scheduledAmount   Float
  frequency         String         // MONTHLY | WEEKLY | QUARTERLY
  fineEnabled       Boolean        @default(true)
  flatFee           Float          @default(0)   // e.g. 200
  dailyRatePercent  Float          @default(0)   // e.g. 0.5 = 0.5% per day
  contributions     Contribution[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Contribution {
  id                String              @id @default(cuid())
  memberId          String
  productId         String
  walletId          String
  scheduledAmount   Float
  amountPaid        Float               @default(0)
  dueDate           DateTime
  paidAt            DateTime?
  status            MonthlyTrackerStatus @default(PENDING)
  
  flatFeeApplied    Float               @default(0)
  dailyRateApplied  Float               @default(0)
  fineStartDate     DateTime?
  
  member            Member              @relation(fields: [memberId], references: [id])
  product           ContributionProduct @relation(fields: [productId], references: [id])
  fineSnapshots     FineSnapshot[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status, dueDate])
  @@index([memberId, dueDate])
}

model FineSnapshot {
  id              String       @id @default(cuid())
  contributionId  String
  snapshotDate    DateTime
  daysPastDue     Int
  flatFee         Float
  dailyPenalty    Float
  totalFine       Float
  contribution    Contribution @relation(fields: [contributionId], references: [id])
  createdAt       DateTime     @default(now())

  @@unique([contributionId, snapshotDate])
  @@index([contributionId])
}


// ========================================
// WELFARE MODULE
// ========================================

enum WelfareStatus {
  PENDING
  APPROVED
  DISBURSED
  REJECTED
  CANCELLED
}

enum WelfareEventType {
  CREATED
  SUBMITTED
  APPROVED
  REJECTED
  DISBURSED
  CANCELLED
}

model WelfareType {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  glAccountId String
  isActive    Boolean @default(true)

  // Relations
  glAccount    LedgerAccount        @relation("WelfareTypeGLAccount", fields: [glAccountId], references: [id])
  requisitions WelfareRequisition[]
  customFields WelfareCustomField[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([glAccountId])
}

model WelfareCustomField {
  id            String  @id @default(cuid())
  welfareTypeId String
  fieldName     String
  fieldType     String // TEXT, NUMBER, DATE, SELECT
  isRequired    Boolean @default(false)
  options       Json? // For SELECT type
  displayOrder  Int     @default(0)

  welfareType WelfareType @relation(fields: [welfareTypeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([welfareTypeId])
}

model WelfareRequisition {
  id                String        @id @default(cuid())
  requisitionNumber String        @unique
  welfareTypeId     String
  memberId          String // The Beneficiary Member
  beneficiaryName   String? // Snapshot of name or external name
  amount            Decimal       @db.Decimal(19, 4)
  reason            String
  customFieldData   Json?
  status            WelfareStatus @default(PENDING)

  // Relations
  welfareType   WelfareType           @relation(fields: [welfareTypeId], references: [id])
  member        Member                @relation("WelfareRequisitionMember", fields: [memberId], references: [id])
  approvals     WelfareApproval[]
  journeyEvents WelfareJourneyEvent[]

  // Disbursement tracking
  disbursedAt    DateTime?
  journalEntryId String?            @unique
  journalEntry   LedgerTransaction? @relation("WelfareJournalEntry", fields: [journalEntryId], references: [id])

  createdById String
  createdBy   User   @relation("WelfareCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([welfareTypeId])
  @@index([memberId])
  @@index([status])
}

model WelfareApproval {
  id            String         @id @default(cuid())
  requisitionId String
  approverId    String
  decision      ApprovalStatus
  notes         String?
  timestamp     DateTime       @default(now())

  requisition WelfareRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  approver    Member             @relation("WelfareApprover", fields: [approverId], references: [id])

  @@unique([requisitionId, approverId])
  @@index([requisitionId])
  @@index([approverId])
}

model WelfareJourneyEvent {
  id            String           @id @default(cuid())
  requisitionId String
  eventType     WelfareEventType
  description   String
  actorId       String?
  timestamp     DateTime         @default(now())

  requisition WelfareRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@index([requisitionId])
}

model WelfareFundTransaction {
  id                  String   @id @default(cuid())
  type                String // CONTRIBUTION, DISBURSEMENT, ADJUSTMENT
  amount              Decimal  @db.Decimal(19, 4)
  description         String
  balanceAfter        Decimal  @db.Decimal(19, 4)
  requisitionId       String? // Auditing
  createdById         String
  createdByName       String?  @default("")
  // Idempotency / External Links
  externalReferenceId String?  @unique // e.g. M-Pesa TransID
  createdBy           User     @relation("WelfareFundCreator", fields: [createdById], references: [id])
  createdAt           DateTime @default(now())

  @@index([createdAt])
}

// ========================================
// NOTIFICATION SYSTEM
// ========================================

model NotificationConfig {
  id        String   @id @default(cuid())
  event     String   @unique // e.g. "LOAN_SUBMISSION", "LOAN_APPROVAL"
  emails    String[] // List of recipient emails
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ========================================
// CENTRALIZED APPROVALS MODULE
// ========================================

// ApprovalType removed - Fully migrated to WorkflowRequest engine.

// ApprovalRequest removed - Fully migrated to WorkflowRequest engine.


enum MpesaTransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

model Transaction {
  id                 String                 @id @default(cuid())
  phoneNumber        String
  amount             Decimal                @db.Decimal(19, 4)
  status             MpesaTransactionStatus @default(PENDING)
  checkoutRequestId  String                 @unique
  mpesaReceiptNumber String?
  failureReason      String?
  memberId           String?
  member             Member?                @relation(fields: [memberId], references: [id])
  createdAt          DateTime               @default(now())
}

model PendingTransaction {
  id                 String    @id @default(uuid())
  walletId           String
  userId             String
  profilePhone       String // Normalized MSISDN from profile
  payingPhone        String // Normalized MSISDN entered in modal
  amount             Decimal   @db.Decimal(19, 4)
  initiatedAt        DateTime  @default(now())
  status             String    @default("pending") // pending, completed, failed, expired
  ncbaReference      String?   @unique
  callbackReceivedAt DateTime?

