  groupId              String   @unique
  group                Group    @relation(fields: [groupId], references: [id])
  maxAllocationPct     Decimal  @default(20.00) @db.Decimal(5, 2)
  maxFloaterExposurePct Decimal  @default(30.00) @db.Decimal(5, 2)
  minTreasuryReservePct Decimal  @default(30.00) @db.Decimal(5, 2)
