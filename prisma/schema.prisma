model GroupInvestmentProposal {
  id                String         @id @default(cuid())
  groupId           String
  group             Group          @relation(fields: [groupId], references: [id])
  loanNoteId        String
  loanNote          LoanNote       @relation(fields: [loanNoteId], references: [id])
  proposedBy        String
  proposedAmount    Decimal        @db.Decimal(15, 2)
  treasuryBalanceAtProposal Decimal @db.Decimal(15, 2)
  pctOfTreasury     Decimal        @db.Decimal(5, 2)
  postInvestmentBalance Decimal    @db.Decimal(15, 2)
  reserveAfterInvestment Decimal   @db.Decimal(5, 2)
  floaterExposurePct Decimal?      @db.Decimal(5, 2)
  status            ProposalStatus @default(PENDING_COMMITTEE_APPROVAL)
  rejectionReason   String?        @db.Text
  expiresAt         DateTime
  businessDate      DateTime       @db.Date
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  votes             GroupInvestmentProposalVote[]

  @@map("group_investment_proposals")
}

model GroupInvestmentProposalVote {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    GroupInvestmentProposal @relation(fields: [proposalId], references: [id])
  voterId     String
  vote        String // "APPROVE" | "REJECT"
  comment     String?  @db.Text
  votedAt     DateTime @default(now())

  @@unique([proposalId, voterId])
  @@map("group_investment_proposal_votes")
}

model EscrowAccount {
  id           String   @id @default(cuid())
  loanNoteId   String   @unique
  loanNote     LoanNote @relation(fields: [loanNoteId], references: [id])
  balance      Decimal  @default(0.00) @db.Decimal(15, 2)
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("escrow_accounts")
}

model LoanNote {
  id                      String         @id @default(cuid())
  referenceNo             String         @unique
  title                   String
  floaterId               String
  floater                 User           @relation("FloaterNotes", fields: [floaterId], references: [id])
  requesterName           String
  requesterRelationship   String?
  purpose                 String         @db.Text
  supportDocUrl           String?
  totalAmount             Decimal        @db.Decimal(15, 2)
  subscribedAmount        Decimal        @default(0.00) @db.Decimal(15, 2)
  minSubscription         Decimal        @db.Decimal(15, 2)
  maxSubscription         Decimal?       @db.Decimal(15, 2)
  interestRate            Decimal        @db.Decimal(5, 2)
  tenorValue              Int
  tenorUnit               String         @default("months")
  repaymentMode           RepaymentMode
  paymentIntervalMonths   Int?
  subscriptionDeadline    DateTime       @db.Date
  closureDate             DateTime?      @db.Date
  maturityDate            DateTime?      @db.Date
  collateral              String?        @db.Text
  repaymentSource         String         @db.Text
  additionalNotes         String?        @db.Text
  status                  LoanNoteStatus @default(PENDING_APPROVAL)
  adminReviewComment      String?        @db.Text
  totalInterestObligation Decimal?       @db.Decimal(15, 2)
  totalPrincipalOwed      Decimal?       @db.Decimal(15, 2)
  totalFloaterObligation  Decimal?       @db.Decimal(15, 2)
  escrowReleased          Boolean        @default(false)
  escrowReleasedAt        DateTime?
  escrowReleasedBy        String?
  escrowReleaseComment    String?        @db.Text
  submissionVersion       Int            @default(0)
  cancellationCount       Int            @default(0)
  version                 Int            @default(1)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

