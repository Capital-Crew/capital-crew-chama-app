// ========================================
// WELFARE MODULE
// ========================================

enum WelfareStatus {
  PENDING
  APPROVED
  DISBURSED
  REJECTED
  CANCELLED
}

enum WelfareEventType {
  CREATED
  SUBMITTED
  APPROVED
  REJECTED
  DISBURSED
  CANCELLED
}

model WelfareType {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  glAccountId String
  isActive    Boolean @default(true)

  // Relations
  glAccount    LedgerAccount        @relation("WelfareTypeGLAccount", fields: [glAccountId], references: [id])
  requisitions WelfareRequisition[]
  customFields WelfareCustomField[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([glAccountId])
}

model WelfareCustomField {
  id            String  @id @default(cuid())
  welfareTypeId String
  fieldName     String
  fieldType     String // TEXT, NUMBER, DATE, SELECT
  isRequired    Boolean @default(false)
  options       Json? // For SELECT type
  displayOrder  Int     @default(0)

  welfareType WelfareType @relation(fields: [welfareTypeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([welfareTypeId])
}

model WelfareRequisition {
  id                String        @id @default(cuid())
  requisitionNumber String        @unique
  welfareTypeId     String
  memberId          String     // The Beneficiary Member
  beneficiaryName   String?    // Snapshot of name or external name
  amount            Decimal       @db.Decimal(19, 4)
  reason            String
  customFieldData   Json?
  status            WelfareStatus @default(PENDING)

  // Relations
  welfareType   WelfareType           @relation(fields: [welfareTypeId], references: [id])
  member        Member                @relation("WelfareRequisitionMember", fields: [memberId], references: [id])
  approvals     WelfareApproval[]
  journeyEvents WelfareJourneyEvent[]

  // Disbursement tracking
  disbursedAt    DateTime?
  journalEntryId String?             @unique
  journalEntry   LedgerTransaction?  @relation("WelfareJournalEntry", fields: [journalEntryId], references: [id])

  createdById String
  createdBy   User   @relation("WelfareCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([welfareTypeId])
  @@index([memberId])
  @@index([status])
}

model WelfareApproval {
  id            String         @id @default(cuid())
  requisitionId String
  approverId    String
  decision      ApprovalStatus
  notes         String?
  timestamp     DateTime       @default(now())

  requisition WelfareRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  approver    Member             @relation("WelfareApprover", fields: [approverId], references: [id])

  @@unique([requisitionId, approverId])
  @@index([requisitionId])
  @@index([approverId])
}

model WelfareJourneyEvent {
  id            String           @id @default(cuid())
  requisitionId String
  eventType     WelfareEventType
  description   String
  actorId       String?
  timestamp     DateTime         @default(now())

  requisition WelfareRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@index([requisitionId])
}

model WelfareFundTransaction {
  id            String   @id @default(cuid())
  type          String // CONTRIBUTION, DISBURSEMENT, ADJUSTMENT
  amount        Decimal  @db.Decimal(19, 4)
  description   String
  balanceAfter  Decimal  @db.Decimal(19, 4)
  requisitionId String? // Auditing
  createdById   String
  createdByName String?  @default("")
  // Idempotency / External Links
  externalReferenceId String? @unique // e.g. M-Pesa TransID
  createdBy     User     @relation("WelfareFundCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

// ========================================
// NOTIFICATION SYSTEM
// ========================================

model NotificationConfig {
  id        String   @id @default(cuid())
  event     String   @unique // e.g. "LOAN_SUBMISSION", "LOAN_APPROVAL"
  emails    String[] // List of recipient emails
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ========================================
// CENTRALIZED APPROVALS MODULE
// ========================================

enum ApprovalType {
  LOAN
  EXPENSE
  MEMBER
  WELFARE
  OTHER
}

model ApprovalRequest {
  id        String   @id @default(cuid())

  // Type & Reference
  type           ApprovalType
  referenceId    String   // ID of the Loan, Expense, Member, etc.
  referenceTable String   // For clarity (e.g. 'Loan')

  // Requester Info
  requesterId    String?  // ID of User/Member requesting
  requesterName  String?

  // Content Snapshot
  description    String?
  amount         Decimal? @db.Decimal(19, 4)

  // Status
  status         ApprovalStatus @default(PENDING)

  // RBAC
  requiredPermission String? // Permission required to view/act (e.g. 'APPROVE_LOANS')

  // Decision
  approverId     String?
  approverName   String?
  decisionNotes  String?
  approvedAt     DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([requesterId])
}

enum MpesaTransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

model Transaction {
  id                 String                 @id @default(cuid())
  phoneNumber        String
  amount             Decimal                @db.Decimal(19, 4)
  status             MpesaTransactionStatus @default(PENDING)
  checkoutRequestId  String                 @unique
  mpesaReceiptNumber String?
  failureReason      String?
  memberId           String?
  member             Member?                @relation(fields: [memberId], references: [id])
  createdAt          DateTime               @default(now())
}




