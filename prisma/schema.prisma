  DAYS
  WEEKS
  MONTHS
}

enum InterestType {
  FLAT
  DECLINING_BALANCE
}

enum InterestCalculationPeriodType {
  DAILY
  SAME_AS_REPAYMENT
}

enum AmortizationType {
  EQUAL_INSTALLMENTS
  EQUAL_PRINCIPAL
}

enum ChargeType {
  FEE
  PENALTY
}

enum ChargeCalculationType {
  FIXED
  PERCENTAGE
}

enum ExpenseCategory {
  OFFICE
  OPERATIONS
  EVENTS
  MISCELLANEOUS
}

enum IncomeCategory {
  MONTHLY_CONTRIBUTION
  LOAN_REPAYMENT
  LOAN_PENALTY
  NON_LOAN_PENALTY
  RESCHEDULING_FEE
  TOP_UP_FEE
  APPLICATION_FEE
}

enum NotificationType {
  APPLICATION_RECEIVED
  LOAN_APPROVED
  LOAN_REJECTED
  LOAN_CLEARED
  SYSTEM_UPDATE
}

enum AuditLogAction {
  LOAN_APPLIED
  LOAN_VOTE_CAST
  LOAN_STATUS_CHANGED
  EXPENSE_REQUEST_CREATED
  MODIFICATION_REQUEST_CREATED
  REQUEST_DECISION_MADE
  FINANCIAL_RECORD_RECORDED
  SETTINGS_UPDATED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  MEMBER_ADDED
  DASHBOARD_VIEWED
  REPORT_DOWNLOADED
  USER_RIGHTS_UPDATED
  FEE_EXEMPTION_CHANGED
  LOAN_APPLICATION_CANCELLED
  LOAN_DISBURSED
  CHARGE_TEMPLATE_CREATED
  WALLET_TRANSACTION_CREATED
  WALLET_TRANSACTION_REVERSED
  WALLET_BALANCE_CHECKED
  MIGRATION
  BULK_MIGRATION
  JOURNAL_REVERSAL
  INTEREST_ENGINE_RUN
  PENALTY_ENGINE_RUN
  EXPENSE_REQUESTED
  EXPENSE_APPROVED
  EXPENSE_REJECTED
  EXPENSE_PAID
  
  // Welfare Events
  WELFARE_REQUISITION_CREATED
  WELFARE_STATUS_CHANGED
  WELFARE_DISBURSED
  WELFARE_TYPE_CREATED
  WELFARE_TYPE_UPDATED
  WELFARE_TYPE_DELETED
}

enum WalletTransactionType {
  CONTRIBUTION // Legacy - kept for existing data
  DEPOSIT // Cash deposit to balance
  LOAN_DISBURSEMENT // Loan credited to wallet
  REPAYMENT // Loan repayment
  FEE // Fees charged
  PENALTY // Penalties
  SHARE_PURCHASE // Buying shares (debit balance, credit equity)
  WITHDRAWAL // Cash withdrawal
  REVERSAL // Reversal transaction
  REFUND // Fee refund
  ADJUSTMENT // Admin adjustment
}

enum LedgerTransactionType {
  SHARE_CONTRIBUTION
  SHARE_REVERSAL
  CASH_DEPOSIT
  CASH_WITHDRAWAL
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  FEE_CHARGE
  FEE_REVERSAL
  CREDIT
}

enum LoanEventType {
  APPLICATION_SUBMITTED
  APPROVAL_RECEIVED
  APPROVAL_REJECTED
  LOAN_APPROVED
  LOAN_REJECTED
  LOAN_DISBURSED
  REPAYMENT_MADE
  PENALTY_APPLIED
  LOAN_CLEARED
  LOAN_RESCHEDULED
  LOAN_TOPPED_UP
}

// ========================================
// CORE LEDGER MODELS (Phase 1)
// ========================================

// Replaces "Account"
model LedgerAccount {
  id               String      @id @default(cuid())
  code             String      @unique
  name             String
  type             AccountType
  subType          String?
  
  // Cached Balance - Updated via transactions
  balance          Decimal     @default(0) @db.Decimal(19, 4)
  
  // Hierarchy
  parentId         String?
  parent           LedgerAccount?    @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children         LedgerAccount[]   @relation("AccountHierarchy")
  
  isActive         Boolean     @default(true)
  allowManualEntry Boolean     @default(false)
  description      String?

  // Relations
  ledgerEntries   LedgerEntry[]
  
  // Mappings (Updated names)
  productMappings ProductAccountingMapping[]
  systemMappings  SystemAccountingMapping[]
  expenses        Expense[]                  @relation("ExpenseAccount")
  welfareTypes    WelfareType[]              @relation("WelfareTypeGLAccount")
  
  // Transfers
  debitTransfers  TransferRequest[] @relation("TransferDebit")

  creditTransfers TransferRequest[] @relation("TransferCredit")
  
  // Wallet Link
  wallets          Wallet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([type])
  @@index([parentId])
}

// Replaces "JournalEntry" - The Atomic Transaction Header
model LedgerTransaction {
  id              String   @id @default(cuid())
  transactionDate DateTime
  postedAt        DateTime @default(now())

  referenceType ReferenceType
  referenceId   String

  description String
  notes       String?

  // Reversal Tracking
  isReversed Boolean @default(false)
  reversedBy String? // ID of the reversal transaction
  reversalOf String? @unique // ID of the original transaction

  // Totals for quick sanity checks
  totalAmount Decimal @db.Decimal(19, 4)

  // The Double Entries
  ledgerEntries LedgerEntry[]

  // Auditing
  createdBy     String
  createdByName String?  @default("")
  createdAt     DateTime @default(now())
  
  // Idempotency / External Links
  externalReferenceId String? @unique // e.g. M-Pesa TransID

  // Specific domain links (Optional, for easier joins)
  welfareRequisition WelfareRequisition? @relation("WelfareJournalEntry")
  
  @@index([referenceType, referenceId])
  @@index([transactionDate])
  @@index([createdAt])
  @@index([externalReferenceId])
}

// Replaces "JournalLine" - The Individual Debits/Credits
model LedgerEntry {
  id                  String            @id @default(cuid())
  ledgerTransactionId String
  ledgerTransaction   LedgerTransaction @relation(fields: [ledgerTransactionId], references: [id], onDelete: Cascade)

  ledgerAccountId String
  ledgerAccount   LedgerAccount @relation(fields: [ledgerAccountId], references: [id])

  // Amounts
  // We keep distinct debit/credit columns for clarity and reporting, 
  // but logically one is 0.
  debitAmount  Decimal @db.Decimal(19, 4) @default(0)
  creditAmount Decimal @db.Decimal(19, 4) @default(0)

  description String?

  @@index([ledgerTransactionId])
  @@index([ledgerAccountId])
}



enum ShareTransactionType {
  CONTRIBUTION // Member contributes to share capital
  REVERSAL // Admin-approved reversal
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE  // Replaces INCOME
  EXPENSE
  INCOME   // Deprecated, aliased to REVENUE
}

enum ReferenceType {
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  LOAN_INTEREST_ACCRUAL
  LOAN_PENALTY_ACCRUAL
  LOAN_FEE_CHARGE
  SAVINGS_DEPOSIT
  SAVINGS_WITHDRAWAL
  SHARE_CONTRIBUTION
  SHARE_REVERSAL
  MANUAL_ADJUSTMENT
  OPENING_BALANCE
  MIGRATION
  REVERSAL
  WELFARE_DISBURSEMENT
}

// Event Sourcing Enums
enum AggregateType {
  LOAN
  MEMBER
  WALLET
  SHARE
  SYSTEM
}

enum DomainEventType {
  // Loan Events
  LOAN_APPLIED
  LOAN_APPROVED
  LOAN_REJECTED
  LOAN_DISBURSED
  REPAYMENT_MADE
  LOAN_CLEARED
  LOAN_RESCHEDULED
  LOAN_TOPPED_UP
  PENALTY_APPLIED

  // Member Events
  MEMBER_REGISTERED
  MEMBER_UPDATED
  MEMBER_DEACTIVATED

  // Wallet Events
  WALLET_CREATED
  WALLET_DEPOSIT_MADE
  WALLET_WITHDRAWAL_MADE

  // Share Events
  SHARE_CONTRIBUTION_MADE
  SHARE_CONTRIBUTION_REVERSED

  // System Events
  SYSTEM_MIGRATION
  SYSTEM_ADJUSTMENT
}

// Models

model User {
  id                 String   @id @default(cuid())
  name               String?
  email              String   @unique
  passwordHash       String
  role               UserRole @default(MEMBER)
  permissions        Json? // Stores UserPermissions object
  memberId           String?  @unique
  member             Member?  @relation(fields: [memberId], references: [id])
  image              String? // Profile picture URL or Base64
  avatarPreset       String? // Selected cartoon avatar identifier
  mustChangePassword Boolean  @default(false)
  failedLoginAttempts Int      @default(0)
  lockoutUntil        DateTime?

  expensesRequested Expense[]         @relation("ExpenseRequester")
  expenseApprovals  ExpenseApproval[]

  // Transfer Approvals
  transferRequests  TransferRequest[]  @relation("TransferRequester")
  transferApprovals TransferApproval[] @relation("TransferApprover")

  // Welfare Relations
  welfareRequisitionsCreated WelfareRequisition[]     @relation("WelfareCreator")
  welfareFundTransactions    WelfareFundTransaction[] @relation("WelfareFundCreator")

  auditLogs AuditLog[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// NEW ENUMS
enum MemberStatus {
  PENDING
  APPROVED
  ACTIVE
  REJECTED
  CLOSED
  WITHDRAWN
}

enum IdentifierType {
  NATIONAL_ID
  PASSPORT
  DRIVERS_LICENSE
  VOTERS_CARD
}

enum CommandResourceType {
  MEMBER
  LOAN
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  members   Member[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id           String  @id @default(cuid())
  memberNumber Int     @unique
  externalId   String? @unique // For data migration / legacy IDs

  // Status & Lifecycle
  status MemberStatus @default(PENDING)

  // Display Information (kept for backward compatibility)
  name    String
  contact String

  // Next of Kin / Beneficiaries
  beneficiaries Json? // Stores Beneficiary[]

  // Legacy Permissions
  canApproveLoan Boolean @default(false)

  // References
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  // SHARE CAPITAL (EQUITY)
  shareContributions Decimal @default(0) @db.Decimal(19, 4)

  // NEW: Contribution Tracking
  contributionArrears Decimal @default(0) @db.Decimal(19, 4)
  penaltyArrears      Decimal @default(0) @db.Decimal(19, 4)

  // PII & Contact Separation (1:1)
  details     MemberDetail?
  contactInfo MemberContact?

  // KYC (1:M)
  identifiers MemberIdentifier[]

  // Relationships
  user              User?
  wallet            Wallet?
  loans             Loan[]
  loanApprovals     LoanApproval[]
  shareTransactions ShareTransaction[]
  incomes           Income[]
  notifications     Notification[]
  generalLedger     GeneralLedger[]
  guaranteedLoans   GuarantorMap[]
  nextOfKin         NextOfKin[]
  mpesaTransactions Transaction[]     // M-Pesa Transactions

  // Welfare Relations
  welfareRequisitions WelfareRequisition[] @relation("WelfareRequisitionMember")
  welfareApprovals    WelfareApproval[]    @relation("WelfareApprover")

  // Audit Trails
  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt

  approvedAt DateTime?
  approvedBy String?

  activatedAt DateTime?
  activatedBy String?

  closedAt DateTime?
  closedBy String?

  // Soft Delete
  deletedAt DateTime?
}

model MemberDetail {
  id       String @id @default(cuid())
  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  firstName     String
  middleName    String?
  lastName      String
  dateOfBirth   DateTime?
  gender        String?
  maritalStatus String?
  nationality   String?
  occupation    String?

  updatedAt DateTime @updatedAt
}

model MemberContact {
  id       String @id @default(cuid())
  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  email           String?
  mobile          String? @unique
  phone           String? // Alterate phone
  physicalAddress String?
  postalAddress   String?
  city            String?

  updatedAt DateTime @updatedAt
}

model MemberIdentifier {
  id       String @id @default(cuid())
  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  type        IdentifierType
  value       String
  documentUrl String?

  createdAt DateTime @default(now())

  @@unique([type, value])
  @@index([memberId])
}

model CommandLog {
  id           String              @id @default(cuid())
  resourceId   String
  resourceType CommandResourceType
  action       String // e.g. "ACTIVATE_MEMBER"

  payloadBefore Json?
  payloadAfter  Json?

  performedBy String
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  @@index([resourceId])
  @@index([performedBy])
  @@index([timestamp])
}

model GuarantorMap {
  id String @id @default(cuid())

  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id])

  guarantorId String
  guarantor   Member @relation(fields: [guarantorId], references: [id])

  amountGuaranteed Float

  createdAt DateTime @default(now())

  @@unique([loanId, guarantorId])
  @@index([loanId])
  @@index([guarantorId])
}

model LoanProduct {
  id          String  @id @default(cuid())
  name        String
  shortCode   String  @unique @default("LP") // Temporary default for migration
  description String?
  currency    String  @default("KES")

  principal    Decimal @db.Decimal(19, 4)
  minPrincipal Decimal @default(0) @db.Decimal(19, 4)
  maxPrincipal Decimal @default(1000000) @db.Decimal(19, 4)

  numberOfRepayments Int
  minRepaymentTerms  Int @default(1)
  maxRepaymentTerms  Int @default(12)

  repaymentEvery         Int
  repaymentFrequencyType RepaymentFrequencyType

  interestRatePerPeriod         Decimal                       @db.Decimal(10, 6)
  interestType                  InterestType
  interestCalculationPeriodType InterestCalculationPeriodType
  amortizationType              AmortizationType

  defaultPenaltyRate Decimal @default(0) @db.Decimal(5, 2)
  gracePeriod        Int     @default(0)

  charges  Json // Stores LoanCharge[]
  isActive Boolean @default(true)

  loans Loan[]

  // NEW: Accounting Configuration
  accountingMappings ProductAccountingMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Loan {
  id                    String      @id @default(cuid())
  loanApplicationNumber String      @unique
  memberId              String
  member                Member      @relation(fields: [memberId], references: [id])
  loanProductId         String
  loanProduct           LoanProduct @relation(fields: [loanProductId], references: [id])

  amount             Decimal    @db.Decimal(19, 4)
  current_balance    Decimal    @default(0) @db.Decimal(19, 4) // Legacy
  outstandingBalance Decimal    @default(0) @db.Decimal(19, 4) // NEW: Strict Decimal Balance
  applicationDate    DateTime
  disbursementDate   DateTime?
  dueDate            DateTime?
  interestRate       Decimal    @db.Decimal(10, 6)
  penalties          Decimal    @default(0) @db.Decimal(19, 4)
  status             LoanStatus @default(PENDING_APPROVAL)

  // Loan Appraisal Calculation Fields
  memberSharesAtApplication Decimal @default(0) @db.Decimal(19, 4)
  grossQualifyingAmount     Decimal @default(0) @db.Decimal(19, 4)
  processingFee             Decimal @default(0) @db.Decimal(19, 4)
  insuranceFee              Decimal @default(0) @db.Decimal(19, 4)
  shareCapitalDeduction     Decimal @default(0) @db.Decimal(19, 4)
  existingLoanOffset        Decimal @default(0) @db.Decimal(19, 4)
  totalDeductions           Decimal @default(0) @db.Decimal(19, 4)
  netDisbursementAmount     Decimal @default(0) @db.Decimal(19, 4)

  approvalVotes             Json // Stores ApprovalVote[] (legacy, kept for migration)
  repaymentSchedule         Json // Stores RepaymentScheduleItem[]
  originalRepaymentSchedule Json? // Stores RepaymentScheduleItem[]
  cachedSchedule            Json? // CACHE: Stores calculated schedule to avoid recalculations

  feeExemptions      Json // Stores FeeExemptions object
  productSnapshot    Json? // Stores snapshot of product at time of loan
  loanContract       String?
  applicationFeePaid Boolean @default(false)

  hasBeenRescheduled Boolean @default(false)
  hasBeenToppedUp    Boolean @default(false)

  // NEW: Penalty Configuration
  penaltyRate Decimal @default(5.0) @db.Decimal(5, 2) // Percentage (e.g., 5%)

  // NEW: Custom Installments & Monthly Payment
  installments       Int     @default(12) // User-selected repayment period in months
  monthlyInstallment Decimal @default(0) @db.Decimal(19, 4) // Calculated EMI/Equal Principal amount

  // NEW: Interest Accrual Tracking
  interestRatePerMonth Decimal           @default(0)
  lastInterestRunDate  DateTime?
  nextInterestRunDate  DateTime          @default(now()) // Gatekeeper for batch runs, defaults to now for new loans
  accruedInterestTotal Decimal           @default(0)
  interestPostings     InterestPosting[]

  // NEW: Penalty Engine
  repaymentInstallments RepaymentInstallment[] @relation("LoanRepaymentInstallments")

  // NEW: Loan Top-Up Relationships
  topUps   LoanTopUp[] @relation("NewLoan") // This loan offsets other loans
  offsetBy LoanTopUp[] @relation("OldLoan") // This loan was offset by another

  approvals          LoanApproval[]
  journeyEvents      LoanJourneyEvent[]
  walletTransactions WalletTransaction[]
  generalLedger      GeneralLedger[]
  guarantors         GuarantorMap[]
  transactions       LoanTransaction[] // NEW: Strict Loan Ledger

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// ========================================



// ========================================
// INTEREST ENGINE MODELS
// ========================================

enum InterestPostingType {
  DISBURSEMENT_ACCRUAL
  MONTHLY_ACCRUAL
}

model InterestPosting {
  id     String @id @default(uuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id])

  amount      Decimal
  periodMonth Int
  periodYear  Int
  type        InterestPostingType

  createdAt DateTime @default(now())

  // Prevent double-posting for the same period and type
  @@unique([loanId, periodMonth, periodYear, type])
  @@index([loanId])
}

// Loan Top-Up / Offset  Tracking
model LoanTopUp {
  id String @id @default(cuid())

  // Relationships
  newLoanId String // The new loan that's paying off old loans
  oldLoanId String // The loan being paid off/offset

  // Display Information
  oldLoanNumber String // e.g., "LN-202511-003"
  productName   String // e.g., "Emergency Loan"

  // Financial Breakdown
  principalBalance Decimal @db.Decimal(19, 4) // Remaining principal on old loan
  accruedInterest  Decimal @db.Decimal(19, 4) // All interest accrued up to offset date
  penalties        Decimal @db.Decimal(19, 4) // Any penalties on old loan
  refinanceFee     Decimal @db.Decimal(19, 4) // Fee for refinancing (% of outstanding)
  totalOffset      Decimal @db.Decimal(19, 4) // Sum of above 4 items

  // Metadata
  offsetDate DateTime @default(now())
  createdAt  DateTime @default(now())

  // Relations
  newLoan Loan @relation("NewLoan", fields: [newLoanId], references: [id], onDelete: Cascade)
  oldLoan Loan @relation("OldLoan", fields: [oldLoanId], references: [id], onDelete: Cascade)

  @@index([newLoanId])
  @@index([oldLoanId])
}

model ChargeTemplate {
  id              String                @id @default(cuid())
  name            String
  chargeType      ChargeType
  calculationType ChargeCalculationType
  amount          Decimal               @db.Decimal(19, 4)
  dueDateOffset   Int
  isActive        Boolean               @default(true)
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  amount      Decimal  @db.Decimal(19, 4)

  // requester
  requesterId String
  requester   User   @relation("ExpenseRequester", fields: [requesterId], references: [id])

  // Status
  status ExpenseStatus @default(PENDING)

  // Approvals
  approvals ExpenseApproval[]

  // Accounting
  expenseAccountId String
  expenseAccount   LedgerAccount @relation("ExpenseAccount", fields: [expenseAccountId], references: [id])

  receiptUrl String?

  category ExpenseCategory? // Legacy, make optional or deprecate

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId])
  @@index([expenseAccountId])
}

// ========================================
// TRANSFER REQUEST SYSTEM (Double Approval)
// ========================================

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
}

model TransferRequest {
  id String @id @default(cuid())

  // Requester
  requesterId String
  requester   User   @relation("TransferRequester", fields: [requesterId], references: [id])

  // Transaction Details
  debitAccountId String
  debitAccount   LedgerAccount @relation("TransferDebit", fields: [debitAccountId], references: [id])

  creditAccountId String

  creditAccount   LedgerAccount @relation("TransferCredit", fields: [creditAccountId], references: [id])

  amount      Decimal @db.Decimal(19, 4)
  description String

  // State
  status TransferStatus @default(PENDING)

  // Approvals
  approvals TransferApproval[]

  // Execution Link
  ledgerEntryId String? // ID of the resulting Journal Entry

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId])
  @@index([status])
}

model TransferApproval {
  id String @id @default(cuid())

  transferRequestId String
  transferRequest   TransferRequest @relation(fields: [transferRequestId], references: [id], onDelete: Cascade)

  approverId String
  approver   User   @relation("TransferApprover", fields: [approverId], references: [id])

  status ApprovalStatus // APPROVED or REJECTED
  notes  String?

  createdAt DateTime @default(now())

  @@unique([transferRequestId, approverId]) // Prevent double voting
}

model ExpenseApproval {
  id        String         @id @default(cuid())
  expenseId String
  expense   Expense        @relation(fields: [expenseId], references: [id])
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  status    ApprovalStatus
  notes     String?
  createdAt DateTime       @default(now())

  @@unique([expenseId, userId])
}

model Income {
  id              String         @id @default(cuid())
  date            DateTime
  memberId        String
  member          Member         @relation(fields: [memberId], references: [id])
  amount          Decimal        @db.Decimal(19, 4)
  category        IncomeCategory
  description     String
  loanId          String?
  transactionId   String
  principalAmount Decimal?       @db.Decimal(19, 4)
  interestAmount  Decimal?       @db.Decimal(19, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  memberId  String
  member    Member           @relation(fields: [memberId], references: [id])
  type      NotificationType
  message   String
  timestamp DateTime         @default(now())
  loanId    String?
  isRead    Boolean          @default(false)
}

model AuditLog {
  id        String         @id @default(cuid())
  timestamp DateTime       @default(now())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  action    AuditLogAction
  details   String

  @@index([timestamp])
  @@index([action])
  @@index([userId])
}

// ShareTransaction - Immutable record of share capital contributions
model ShareTransaction {
  id       String @id @default(cuid())
  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  type        ShareTransactionType // CONTRIBUTION, REVERSAL
  amount      Decimal              @db.Decimal(19, 4) // Always positive
  description String

  // Audit & Immutability
  createdAt   DateTime @default(now())
  createdBy   String // User ID who created
  creatorName String
  isReversed  Boolean  @default(false)
  reversalId  String?  @unique // If reversed, points to reversal transaction
  reverses    String?  @unique // If this is a reversal, points to original

  // Accounting Link
  ledgerEntryId String?        @unique
  ledgerEntry   GeneralLedger?

  // Metadata
  metadata Json?

  @@index([memberId, createdAt])
}


enum WalletStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  CLOSED
}

model Wallet {
  id       String  @id @default(cuid())
  
  memberId String  @unique
  member   Member  @relation(fields: [memberId], references: [id])

  // Core Banking Link
  accountRef   String @unique // Paybill "Account Reference"
  glAccountId  String // The underlying Liability Ledger Account (Many Wallets -> One Liability Account)
  glAccount    LedgerAccount @relation(fields: [glAccountId], references: [id])

  currency String       @default("KES")
  status   WalletStatus @default(ACTIVE)

  // balance IS REMOVED. Use glAccount.balance

  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model WalletTransaction {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])

  type        WalletTransactionType
  amount      Decimal               @db.Decimal(19, 4)
  description String

  relatedLoanId String?
  relatedLoan   Loan?   @relation(fields: [relatedLoanId], references: [id])

  balanceAfter Decimal @db.Decimal(19, 4)
  immutable    Boolean @default(true)

  reversedBy String? // ID of reversal transaction
  reverses   String? // ID of transaction being reversed

  generalLedger GeneralLedger?

  createdAt DateTime @default(now())
  
  @@index([walletId])
  @@index([createdAt])
}

model GeneralLedger {
  id              String                @id @default(uuid())
  transactionType LedgerTransactionType
  description     String
  amount          Decimal               @db.Decimal(19, 4)

  // Double Entry Accounts (optional for migration)
  debitAccount  String? @default("") // e.g., "MEMBER_WALLET_123"
  creditAccount String? @default("") // e.g., "MEMBER_SHARE_CAPITAL_123"

  // Links to source transactions
  walletTransactionId String?            @unique
  walletTransaction   WalletTransaction? @relation(fields: [walletTransactionId], references: [id])

  shareTransactionId String?           @unique
  shareTransaction   ShareTransaction? @relation(fields: [shareTransactionId], references: [id])

  loanId String?
  loan   Loan?   @relation(fields: [loanId], references: [id])

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id])

  // Audit (optional for migration)
  createdAt   DateTime @default(now())
  createdBy   String?  @default("")
  creatorName String?  @default("")

  // Metadata
  metadata Json?

  @@index([memberId, createdAt])
  @@index([transactionType, createdAt])
}

model SaccoSettings {
  id                   String  @id @default(cuid())
  loanMultiplier       Decimal @default(3.0) @db.Decimal(5, 2)
  processingFeePercent Decimal @default(0.0) @db.Decimal(5, 2)
  insuranceFeePercent  Decimal @default(0.0) @db.Decimal(5, 2)
  shareCapitalBoost    Decimal @default(0.0) @db.Decimal(5, 2)
  requiredApprovals    Int     @default(3) // Number of approvals needed for loan disbursement

  // NEW: Loan Top-Up Settings
  // NEW: Loan Top-Up Settings
  refinanceFeePercentage Decimal @default(5.0) @db.Decimal(5, 2) // Default 5% of outstanding balance
  allowLoanTopUp         Boolean @default(true)

  // NEW: Reschedule Settings
  rescheduleFeePercent Decimal @default(0.0) @db.Decimal(5, 2)

  // NEW: Penalty Settings
  penaltyRate Decimal @default(5.0) @db.Decimal(5, 2) // Default 5% penalty on overdue installment

  // NEW: Workflow Settings
  requiredApprovalsReschedule Int @default(3)
  requiredApprovalsTopUp      Int @default(3)

  // Welfare Settings
  requiredWelfareApprovals   Int     @default(2)
  welfareMonthlyContribution Decimal @default(0) @db.Decimal(19, 4)
  welfareCurrentBalance      Decimal @default(0) @db.Decimal(19, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NEW: Contribution Settings
  monthlyContributionAmount Decimal @default(2000) @db.Decimal(19, 4)
  latePaymentPenalty        Decimal @default(200) @db.Decimal(19, 4)
}

model LoanApproval {
  id         String         @id @default(cuid())
  loanId     String
  loan       Loan           @relation(fields: [loanId], references: [id])
  approverId String
  approver   Member         @relation(fields: [approverId], references: [id])
  decision   ApprovalStatus
  notes      String?
  timestamp  DateTime       @default(now())

  @@index([loanId])
  @@index([approverId])
}

model LoanJourneyEvent {
  id          String        @id @default(uuid())
  loanId      String
  loan        Loan          @relation(fields: [loanId], references: [id])
  eventType   LoanEventType
  description String
  actorId     String?
  actorName   String?
  metadata    Json?
  timestamp   DateTime      @default(now())

  @@index([loanId])
}

