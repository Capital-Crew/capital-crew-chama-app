model LoanNotePaymentSchedule {
  id                    String           @id @default(cuid())
  loanNoteId            String
  loanNote              LoanNote         @relation(fields: [loanNoteId], references: [id])
  eventNumber           Int
  paymentType           CLNPaymentType
  dueDate               DateTime         @db.Date
  periodLabel           String?
  groupAmount           Decimal          @db.Decimal(15, 2)
  principalComponent    Decimal          @default(0.00) @db.Decimal(15, 2)
  interestComponent     Decimal          @default(0.00) @db.Decimal(15, 2)
  openingBalance        Decimal?         @db.Decimal(15, 2)
  closingBalance        Decimal?         @db.Decimal(15, 2)
  isStubPeriod          Boolean          @default(false)
  stubPeriodMonths      Int?
  status                CLNPaymentStatus @default(UPCOMING)
  sufficiencyCheckedAt  DateTime?
  floaterWalletAtCheck  Decimal?         @db.Decimal(15, 2)
  floaterConfirmed      Boolean          @default(false)
  floaterConfirmedAt    DateTime?
  adminConfirmed        Boolean          @default(false)
  adminConfirmedAt      DateTime?
  executedAt            DateTime?
  gracePeriodDueDate    DateTime?        @db.Date
  gracePeriodGrantedBy  String?
  gracePeriodReason     String?          @db.Text
  disputeRaisedBy       String?
  disputeReason         String?          @db.Text
  disputeResolvedAt     DateTime?
  version               Int              @default(1)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  disbursements         LoanNotePaymentDisbursement[]

  @@unique([loanNoteId, eventNumber])
  @@map("loan_note_payment_schedule")
}

model LoanNotePaymentDisbursement {
