// Universal Approval System
enum EntityType {
  LOAN
  MEMBER
  EXPENSE
  WELFARE
  ACCOUNT_TRANSFER
  LOAN_NOTE
  LOAN_NOTE_PAYMENT
  LOAN_NOTE_SETTLEMENT
}

enum ApprovalAction {
  SUBMITTED
  CANCELLED
  APPROVED
  REJECTED
}

model ApprovalHistory {
  id            String         @id @default(cuid())
  entityType    EntityType
  entityId      String
  actorUsername String
  actorId       String?
  action        ApprovalAction
  timestamp     DateTime       @default(now())
  metadata      Json?

  @@index([entityType, entityId])
}

// Approval Delegation System
// Allows users to delegate their approval authority to others
model ApprovalDelegation {
  id         String      @id @default(cuid())
  fromUserId String // User delegating their authority
  toUserId   String // User receiving the authority
  entityType EntityType? // Optional: Limit to specific entity type
  entityId   String? // Optional: Limit to specific entity
  expiresAt  DateTime? // Optional: Auto-expire delegation
  createdAt  DateTime    @default(now())
  revokedAt  DateTime? // When delegation was manually revoked

  // Relations
  fromUser User @relation("DelegationsFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("DelegationsTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId, toUserId])
  @@index([toUserId, entityType])
  @@index([toUserId, expiresAt])
}

// ========================================
// WORKFLOW ENGINE MODELS
// ========================================

enum WorkflowStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  DRAFT
}

model WorkflowDefinition {
  id          String     @id @default(cuid())
  entityType  EntityType @unique // One workflow per entity type for now (e.g. LOAN)
  name        String
  description String?
  isActive    Boolean    @default(true)

  stages   WorkflowStage[]
  requests WorkflowRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkflowStage {
  id         String             @id @default(cuid())
  workflowId String
  workflow   WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  stepNumber       Int
  name             String
  requiredRole     UserRole
  canReject        Boolean  @default(true)
  isFinal          Boolean  @default(false)
  minVotesRequired Int      @default(1) // Number of approvals needed

  // Reverse relation for current stage tracking
  currentInRequests WorkflowRequest[]

  // Reverse relation for actions taken in this stage
  actions WorkflowAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workflowId, stepNumber])
}

model WorkflowRequest {
  id         String             @id @default(cuid())
  workflowId String
  workflow   WorkflowDefinition @relation(fields: [workflowId], references: [id])

  // Track progress
  currentStageId String?
  currentStage   WorkflowStage? @relation(fields: [currentStageId], references: [id])

  status WorkflowStatus @default(PENDING)

  // Entity Reference
  entityType EntityType
  entityId   String

  // Requester
  requesterId String
  requester   User   @relation(fields: [requesterId], references: [id])

  // History
  actions WorkflowAction[]

  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([status])
  @@index([requesterId])
}

model WorkflowAction {
  id        String          @id @default(cuid())
  requestId String
  request   WorkflowRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  stageId String
  stage   WorkflowStage @relation(fields: [stageId], references: [id])

  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  action    ApprovalAction
  notes     String?
  timestamp DateTime       @default(now())

  @@index([requestId])
  @@index([actorId])
}

// --- RBAC System ---

model SystemModule {
  id          String           @id @default(cuid())
  key         String           @unique // e.g., "LOANS"
  name        String // e.g., "Loans Management"
  description String?
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  id        String       @id @default(cuid())
  role      UserRole
  moduleKey String
  module    SystemModule @relation(fields: [moduleKey], references: [key])
  canAccess Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([role, moduleKey])
}

// ========================================
// EMAIL NOTIFICATION SYSTEM
