generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  SYSTEM_ADMIN // Full access
  CHAIRPERSON
  TREASURER
  SECRETARY
  MEMBER
}

enum LoanStatus {
  PENDING_APPROVAL
  APPROVED
  DISBURSED
  ACTIVE
  CLEARED
  OVERDUE
  REJECTED
  CANCELLED
  WRITTEN_OFF
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

