  subscriptions           LoanNoteSubscription[]
  paymentSchedule         LoanNotePaymentSchedule[]
  proposals               GroupInvestmentProposal[]
  disbursements           LoanNotePaymentDisbursement[]
  auditLogs               LoanNoteAuditLog[]
  escrowLedger            EscrowLedger[] @relation("LoanNoteEscrowLedger")

