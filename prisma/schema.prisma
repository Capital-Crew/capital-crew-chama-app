// ========================================
// INTEREST ENGINE MODELS
// ========================================

enum InterestPostingType {
  DISBURSEMENT_ACCRUAL
  MONTHLY_ACCRUAL
}

model InterestPosting {
  id     String @id @default(uuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id])

  amount      Decimal
  periodMonth Int
  periodYear  Int
  type        InterestPostingType

  createdAt DateTime @default(now())
  runId     String?
  run       InterestEngineRun? @relation(fields: [runId], references: [id])

  // Prevent double-posting for the same period and type
  @@unique([loanId, periodMonth, periodYear, type])
  @@index([loanId])
}

// Loan Top-Up / Offset  Tracking
model LoanTopUp {
  id String @id @default(cuid())

  // Relationships
  newLoanId String // The new loan that's paying off old loans
  oldLoanId String // The loan being paid off/offset

  // Display Information
  oldLoanNumber String // e.g., "LN-202511-003"
  productName   String // e.g., "Emergency Loan"

  // Financial Breakdown
  principalBalance Decimal @db.Decimal(19, 4) // Remaining principal on old loan
  accruedInterest  Decimal @db.Decimal(19, 4) // All interest accrued up to offset date
  penalties        Decimal @db.Decimal(19, 4) // Any penalties on old loan
  refinanceFee     Decimal @db.Decimal(19, 4) // Fee for refinancing (% of outstanding)
  totalOffset      Decimal @db.Decimal(19, 4) // Sum of above 4 items

  // Metadata
  offsetDate DateTime @default(now())
  createdAt  DateTime @default(now())

  // Relations
  newLoan Loan @relation("NewLoan", fields: [newLoanId], references: [id], onDelete: Cascade)
  oldLoan Loan @relation("OldLoan", fields: [oldLoanId], references: [id], onDelete: Cascade)

  @@index([newLoanId])
  @@index([oldLoanId])
}

model ChargeTemplate {
  id              String                @id @default(cuid())
  name            String
  chargeType      ChargeType
  calculationType ChargeCalculationType
  amount          Decimal               @db.Decimal(19, 4)
  dueDateOffset   Int
  isActive        Boolean               @default(true)
}

enum ExpenseStatus {
  DRAFT
  PENDING_APPROVAL
  DISBURSED // Imprest: advance sent to user
  SURRENDERED // Imprest: user reported actuals
  CLOSED // Fully settled
  REJECTED
  REVERSED // Reversal of an approved/disbursed expense
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  description String

  // Expense Type
  type ExpenseType @default(OPERATIONAL)

  // Amounts
  requestedAmount Decimal  @db.Decimal(19, 4) // What was originally asked for
  approvedAmount  Decimal? @db.Decimal(19, 4) // What admin actually approved/disbursed
  actualAmount    Decimal? @db.Decimal(19, 4) // What was actually spent (filled during surrender)
  amount          Decimal  @db.Decimal(19, 4) // Legacy / display amount

  // Requester
  requesterId String
  requester   User   @relation("ExpenseRequester", fields: [requesterId], references: [id])

  // Recipient — the member who receives the payout (optional)
  recipientId String?
  recipient   Member? @relation("ExpenseRecipient", fields: [recipientId], references: [id])

  // Status
  status ExpenseStatus @default(PENDING_APPROVAL)

  // Accounting
  expenseAccountId String
  expenseAccount   LedgerAccount @relation("ExpenseAccount", fields: [expenseAccountId], references: [id])

  receiptUrl String?

  // Surrender / Settlement
  surrenderDate DateTime?
  balanceAction BalanceAction?

  category ExpenseCategory? // Legacy, kept for backward compatibility

  // Relational category
  subCategoryId String?
  subCategory   ExpenseSubCategory? @relation(fields: [subCategoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId])
  @@index([expenseAccountId])
  @@index([subCategoryId])
  @@index([recipientId])
}

// ========================================
// EXPENSE CATEGORY HIERARCHY
// ========================================

model ExpenseCategoryGroup {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique // URL-safe key, e.g. "member-returns"
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  subCategories ExpenseSubCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseSubCategory {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique // URL-safe key, e.g. "dividend-payments"
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  groupId String
  group   ExpenseCategoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
}

// ========================================
// BATCH PAYMENTS (Dividends, Interest)
// ========================================

model BatchPayment {
  id          String             @id @default(cuid())
  title       String // e.g. "Dec 2025 Dividends"
  description String?
  totalAmount Decimal            @db.Decimal(19, 4)
  status      BatchPaymentStatus @default(DRAFT)
  type        String // "DIVIDEND" | "INTEREST" | "BONUS"

  createdById String
  createdBy   User   @relation("BatchCreator", fields: [createdById], references: [id])

  items BatchItem[]

  journalEntryId String? // Link to accounting JE

  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BatchItem {
  id      String       @id @default(cuid())
  batchId String
  batch   BatchPayment @relation(fields: [batchId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  amount Decimal @db.Decimal(19, 4)
  status String  @default("PENDING") // PENDING | PAID | FAILED

  walletTransactionId String? // Reference to the wallet credit

  error     String? // Error message if failed
  createdAt DateTime @default(now())

  @@index([batchId])
  @@index([memberId])
}

// ========================================
// TRANSFER REQUEST SYSTEM (Double Approval)
// ========================================

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
}

model TransferRequest {
  id String @id @default(cuid())

  // Requester
  requesterId String
  requester   User   @relation("TransferRequester", fields: [requesterId], references: [id])

  // Transaction Details
  debitAccountId String
  debitAccount   LedgerAccount @relation("TransferDebit", fields: [debitAccountId], references: [id])

  creditAccountId String

  creditAccount LedgerAccount @relation("TransferCredit", fields: [creditAccountId], references: [id])

  amount      Decimal @db.Decimal(19, 4)
  description String

  // State
  status TransferStatus @default(PENDING)

  // Approvals
  approvals TransferApproval[]

  // Execution Link
  ledgerEntryId String? // ID of the resulting Journal Entry

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId])
  @@index([status])
}

model TransferApproval {
  id String @id @default(cuid())

  transferRequestId String
  transferRequest   TransferRequest @relation(fields: [transferRequestId], references: [id], onDelete: Cascade)

  approverId String
  approver   User   @relation("TransferApprover", fields: [approverId], references: [id])

  status ApprovalStatus // APPROVED or REJECTED
  notes  String?

  createdAt DateTime @default(now())

  @@unique([transferRequestId, approverId]) // Prevent double voting
}

model Revenue {
  id              String          @id @default(cuid())
  date            DateTime        @default(now())
  memberId        String
  member          Member          @relation(fields: [memberId], references: [id])
  amount          Decimal         @db.Decimal(19, 4)
  category        RevenueCategory
  description     String
  loanId          String?
  transactionId   String

  principalAmount Decimal?        @db.Decimal(19, 4)
  interestAmount  Decimal?        @db.Decimal(19, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  memberId  String
  member    Member           @relation(fields: [memberId], references: [id])
  type      NotificationType
  message   String
  timestamp DateTime         @default(now())
  loanId    String?
  isRead    Boolean          @default(false)
}

model AuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  // Identity enrichment
  userEmail   String? // Nullable for legacy logs
  userRole    String? // Nullable for legacy logs
  ipAddress   String? // Existing
  userAgent   String? // Nullable for legacy logs
  sessionId   String? // Existing field in logic but maybe not in DB? No, it was missing.
  geolocation String?

  // What happened
  action     AuditLogAction // Existing
  actionType AuditLogAction? // New field for upgraded tracking
  domain     String? // New (was context)
  details    String? // Existing
  summary    String? // Existing
  context    String? // Existing alias for domain

  // Entity tracking
  entityType String? @default("unknown")
  entityId   String? @default("unknown")

  // Request tracking
  requestId  String?
  apiRoute   String?
  httpMethod String? @default("POST")

  // Outcome
  status        AuditStatus? @default(SUCCESS)
  severity      String? // Existing String field
  severityLevel Severity?    @default(INFO)
  errorCode     String?
  errorStack    String?
  durationMs    Int? // Existing

  // Execution detail
  steps    Json? // Existing
  snapshot Json? // Existing
  metadata Json? // Existing

  // State diff
  stateBefore Json?
  stateAfter  Json?
  diff        Json?

  @@index([timestamp])
  @@index([userId])
  @@index([entityId, entityType])
  @@index([action])
  @@index([sessionId])
  @@index([requestId])
  @@index([createdAt])
  @@index([context])
  @@index([severity])
}

model ReversalLog {
  id         String   @id @default(cuid())
  targetType String // LOAN, SAVINGS, SHARE, EXPENSE
  targetId   String // ID of the reversed transaction
  reason     String
  adminId    String
  timestamp  DateTime @default(now())
}

// ContributionTransaction - Immutable record of contributions (formerly shares)
model ContributionTransaction {
  id       String @id @default(cuid())
  memberId String
  member   Member @relation("MemberContributions", fields: [memberId], references: [id])

  walletId String?
  wallet   Wallet? @relation(fields: [walletId], references: [id])

  type        ContributionTransactionType // CONTRIBUTION, REVERSAL
  amount      Decimal                     @db.Decimal(19, 4) // Always positive
  description String

  // Audit & Immutability
  createdAt   DateTime @default(now())
  createdBy   String?  @default("")
  creatorName String?  @default("")
  isReversed  Boolean  @default(false)
  reversalId  String?  @unique // If reversed, points to reversal transaction
  reverses    String?  @unique // If this is a reversal, points to original

  // Accounting Link
  ledgerTransaction   GeneralLedger?
  ledgerTransactionId String?        @unique

  // Metadata
  metadata Json?

  @@index([memberId, createdAt])
}


enum WalletStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  CLOSED
}

model Wallet {
  id String @id @default(cuid())

  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id])

  // Core Banking Link
  accountRef  String        @unique // Paybill "Account Reference"
  glAccountId String // The underlying Liability Ledger Account (Many Wallets -> One Liability Account)
  glAccount   LedgerAccount @relation(fields: [glAccountId], references: [id])

  currency String       @default("KES")
  status   WalletStatus @default(ACTIVE)

  // balance IS REMOVED. Use glAccount.balance

  transactions             WalletTransaction[]
  contributionTransactions ContributionTransaction[]
  pendingTransactions      PendingTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])

  type        WalletTransactionType
  amount      Decimal               @db.Decimal(19, 4)
  description String

  relatedLoanId String?
  relatedLoan   Loan?   @relation(fields: [relatedLoanId], references: [id])

  balanceAfter Decimal @db.Decimal(19, 4)
  immutable    Boolean @default(true)

  isReversed Boolean @default(false)

  reversedBy String? // ID of reversal transaction
  reverses   String? // ID of transaction being reversed

  generalLedger GeneralLedger?

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([createdAt])
}

model GeneralLedger {
  id              String                @id @default(uuid())
  transactionType LedgerTransactionType
  description     String
  amount          Decimal               @db.Decimal(19, 4)

  // Double Entry Accounts (optional for migration)
  debitAccount  String? @default("") // e.g., "MEMBER_WALLET_123"
  creditAccount String? @default("") // e.g., "MEMBER_SHARE_CAPITAL_123"

  // Links to source transactions
  walletTransactionId String?            @unique
  walletTransaction   WalletTransaction? @relation(fields: [walletTransactionId], references: [id])

  contributionTransactionId String?                 @unique
  contributionTransaction   ContributionTransaction? @relation(fields: [contributionTransactionId], references: [id])

  loanId String?
  loan   Loan?   @relation(fields: [loanId], references: [id])

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id])

  // Audit (optional for migration)
  createdAt   DateTime @default(now())
  createdBy   String?  @default("")
  creatorName String?  @default("")

  // Metadata
  metadata Json?

  @@index([memberId, createdAt])
  @@index([transactionType, createdAt])
}

model SaccoSettings {
  id                   String  @id @default(cuid())
  loanMultiplier       Decimal @default(3.0) @db.Decimal(5, 2)
  processingFeePercent Decimal @default(0.0) @db.Decimal(5, 2)
  insuranceFeePercent  Decimal @default(0.0) @db.Decimal(5, 2)
  contributionBoost    Decimal @default(0.0) @db.Decimal(5, 2)
  requiredApprovals    Int     @default(3) // Number of approvals needed for loan disbursement

  // NEW: Loan Top-Up Settings
  // NEW: Loan Top-Up Settings
  refinanceFeePercentage Decimal @default(5.0) @db.Decimal(5, 2) // Default 5% of outstanding balance
  allowLoanTopUp         Boolean @default(true)

  // NEW: Reschedule Settings
  rescheduleFeePercent Decimal @default(0.0) @db.Decimal(5, 2)

  // NEW: Penalty Settings
  penaltyRate Decimal @default(5.0) @db.Decimal(5, 2) // Default 5% penalty on overdue installment

  // NEW: Workflow Settings
  requiredApprovalsReschedule Int @default(3)
  requiredApprovalsTopUp      Int @default(3)
  
  // NEW: CLN Governance Settings
  clnFloaterSelfApproval      Boolean @default(true)
  requiredApprovalsCLN        Int @default(1) // Listing
  requiredApprovalsCLNPayment  Int @default(2) // Returns
  requiredApprovalsCLNSettlement Int @default(2) // Settlement

  // Welfare Settings
  requiredWelfareApprovals   Int     @default(2)
  welfareMonthlyContribution Decimal @default(0) @db.Decimal(19, 4)
  welfareCurrentBalance      Decimal @default(0) @db.Decimal(19, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NEW: Contribution Settings
  monthlyContributionAmount Decimal @default(2000) @db.Decimal(19, 4)
  latePaymentPenalty        Decimal @default(200) @db.Decimal(19, 4)

  // NEW: Meeting & Penalty Configuration
  penaltyAbsentAmount Decimal @default(500) @db.Decimal(19, 4)
  penaltyLateAmount   Decimal @default(200) @db.Decimal(19, 4)

  meetingFeesGlId String?
  meetingFeesGl   LedgerAccount? @relation("MeetingFeesIncome", fields: [meetingFeesGlId], references: [id])

  meetingReceivableGlId String?
  meetingReceivableGl   LedgerAccount? @relation("MeetingFeesReceivable", fields: [meetingReceivableGlId], references: [id])
}

// ========================================
// MEETING MANAGEMENT MODULE
// ========================================

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  APOLOGY
  APOLOGY_APPROVED
  APOLOGY_REJECTED
}

model Meeting {
  id         String   @id @default(cuid())
  title      String
  date       DateTime
  minutesUrl String? // Path to uploaded PDF

  status MeetingStatus @default(SCHEDULED)

  isPenaltiesProcessed Boolean   @default(false)
  processedAt          DateTime?

  attendees MeetingAttendee[]
  fines     AttendanceFine[]
  apologies Apology[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MeetingAttendee {
  id String @id @default(cuid())

  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  status      AttendanceStatus @default(PRESENT)
  minutesLate Int?             @default(0) // Only relevant if LATE

  isFinalized Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([meetingId, memberId])
  @@index([memberId])
  @@index([meetingId])
}
enum ApologyStatus {
  PENDING
  APPROVED
  REJECTED
}

model Apology {
  id        String        @id @default(cuid())
  meetingId String
  meeting   Meeting       @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  status    ApologyStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

enum AttendanceFineStatus {
  PENDING
  PAID
  WAIVED
}

model AttendanceFine {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id])

  amount Decimal @db.Decimal(19, 4)
  reason String // e.g. "Absent from AGM"

  status AttendanceFineStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([meetingId, userId])
  @@index([userId])
  @@index([status])
}

// Legacy tables preserved to avoid data loss. 
// Do not delete these models unless you have migrated or no longer need the data.
// Removed LegacyAttendance and LegacyPenaltyBill

model LoanApproval {
  id         String         @id @default(cuid())
  loanId     String
  loan       Loan           @relation(fields: [loanId], references: [id])
  approverId String
  approver   Member         @relation(fields: [approverId], references: [id])
  decision   ApprovalStatus
  notes      String?
  timestamp  DateTime       @default(now())
  version    Int            @default(1)

  @@index([loanId])
  @@index([approverId])
}

model InterestEngineRun {
  id                String            @id @default(uuid())
  startedAt         DateTime          @default(now())
  completedAt       DateTime?
  status            String            @default("RUNNING") // RUNNING, SUCCESS, FAILED, REVERSED
