  totalInterest     Decimal           @default(0) @db.Decimal(19, 4)
  error             String?
  postings          InterestPosting[]
  transactions      LoanTransaction[]
  loanId            String?
  loan              Loan?             @relation(fields: [loanId], references: [id])

  @@index([status])
  @@index([startedAt])
