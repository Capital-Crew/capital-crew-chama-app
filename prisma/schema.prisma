  loanNoteId           String
  loanNote             LoanNote              @relation(fields: [loanNoteId], references: [id])
  subscriptionId       String
  subscription         LoanNoteSubscription  @relation(fields: [subscriptionId], references: [id])
  subscriberType       SubscriberType
  subscriberId         String?
  groupId              String?
  paymentType          CLNPaymentType
  exactAmount          Decimal               @db.Decimal(18, 6)
  amount               Decimal               @db.Decimal(15, 2)
  principalComponent   Decimal               @default(0.00) @db.Decimal(15, 2)
  interestComponent    Decimal               @default(0.00) @db.Decimal(15, 2)
  isResidualRecipient  Boolean               @default(false)
  residualAmount       Decimal?              @default(0.00) @db.Decimal(15, 2)
  walletCredited       Boolean               @default(false)
  creditedAt           DateTime?
  businessDate         DateTime              @db.Date
  status               CLNDisbursementStatus @default(PENDING)

  @@map("loan_note_payment_disbursements")
}

model EscrowLedger {
  id              String   @id @default(cuid())
  loanNoteId      String
  loanNote        LoanNote @relation("LoanNoteEscrowLedger", fields: [loanNoteId], references: [id])
  subscriptionId  String?
  subscription    LoanNoteSubscription? @relation(fields: [subscriptionId], references: [id])
  ledgerTxId      String?
  amount          Decimal  @db.Decimal(15, 2)
  direction       String   @db.VarChar(10) // "IN" | "OUT"
  reason          String
  performedBy     String?
  businessDate    DateTime @db.Date
  createdAt       DateTime @default(now())

  @@map("escrow_ledger")
}

model LoanNoteAuditLog {
  id           String   @id @default(cuid())
  loanNoteId   String
  loanNote     LoanNote @relation(fields: [loanNoteId], references: [id])
  action       String
  performedBy  String
  notes        String?  @db.Text
  metadata     Json?
  businessDate DateTime @db.Date
  createdAt    DateTime @default(now())

  @@map("loan_note_audit_log")
}


model ErrorAuditLog {
  id               String   @id @default(cuid())
  errorCode        String
  technicalMessage String
  stack            String?
  userId           String?
  requestId        String   @unique
  endpoint         String?
  method           String?
  correlationId    String?
  affectedEntityId String?
  metadata         Json?
  timestamp        DateTime @default(now())

  @@index([errorCode])
  @@index([requestId])
  @@index([userId])
  @@index([timestamp])
}
