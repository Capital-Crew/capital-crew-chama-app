model LoanJourneyEvent {
  id          String        @id @default(uuid())
  loanId      String
  loan        Loan          @relation(fields: [loanId], references: [id])
  eventType   LoanEventType
  description String
  actorId     String?
  actorName   String?
  metadata    Json?
  timestamp   DateTime      @default(now())

  @@index([loanId])
}

// ========================================
// ACCOUNTING ENGINE MODELS
// ========================================

// Journal Entry (Header)

// Journal Line (Detail)

// ========================================
// EVENT SOURCING MODELS
// ========================================

// Domain Event Store - Immutable Event Log
model DomainEvent {
  id String @id @default(uuid())

  // Aggregate Info
  aggregateType AggregateType
  aggregateId   String

  // Event Info
  eventType    DomainEventType
  eventVersion Int             @default(1)

  // Temporal Info
  timestamp DateTime @default(now())

  // Actor Info
  actorId   String
  actorName String

  // Event Data
  metadata Json // Event-specific data

  // Event Chain
  causationId   String? // Event that caused this
  correlationId String? // Original request/command ID

  // Indexes for fast queries
  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@index([timestamp])
  @@index([aggregateType, aggregateId, timestamp])
  @@index([correlationId])
}

// Loan Summary Projection - Fast Read Model
model LoanSummaryProjection {
  loanId String @id

  // Financial Summary
  totalDisbursed     Float @default(0)
  totalRepaid        Float @default(0)
  outstandingBalance Float @default(0)

  // Dates
  disbursementDate DateTime?
  lastPaymentDate  DateTime?
  nextDueDate      DateTime?

  // Status
  status String

  // Event Tracking
  lastEventId String // For idempotency
  lastUpdated DateTime @default(now())

  @@index([status])
  @@index([nextDueDate])
}

// Member Balance Projection - Fast Read Model
model MemberBalanceProjection {
  memberId String @id

  // Balances
  walletBalance Float @default(0)
  contributionBalance Float @default(0)

  // Loan Summary
  totalLoansActive      Int   @default(0)
  totalLoansDisbursed   Float @default(0)
  totalLoansOutstanding Float @default(0)

  // Event Tracking
  lastEventId String // For idempotency
  lastUpdated DateTime @default(now())

  @@index([lastUpdated])
}

enum NextOfKinRelationship {
  SPOUSE
  CHILD
  PARENT
  SIBLING
  OTHER
}

model NextOfKin {
  id       String @id @default(cuid())
  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  fullName     String
  relationship String // MATCHES ENUM IN ZOD
  nationality  String // ISO Country Code (e.g., KE, US)
  phoneNumber  String
  altPhone     String?
  allocation   Decimal @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
}

// ========================================
enum PenaltyStatus {
  NONE
  PENDING
  APPLIED
}

// ========================================
// ACCOUNTING MAPPING MODELS
