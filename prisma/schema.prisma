// ========================================
// STRICT LOAN LEDGER
// ========================================

enum LoanTransactionType {
  DISBURSEMENT
  REPAYMENT
  INTEREST
  PENALTY
  WAIVER
}

model LoanTransaction {
  id     String @id @default(cuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id])

  type   LoanTransactionType
  amount Decimal             @db.Decimal(15, 2)

  description String?
  referenceId String? // External Ref (e.g. JE Number)

  isReversed Boolean @default(false)

  // Specific Allocation (For Audit & Replay)
  principalAmount Decimal @default(0) @db.Decimal(15, 2)
  interestAmount  Decimal @default(0) @db.Decimal(15, 2)
  penaltyAmount   Decimal @default(0) @db.Decimal(15, 2)
  feeAmount       Decimal @default(0) @db.Decimal(15, 2)

  postedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([loanId, isReversed])
  @@index([createdAt])
  @@index([postedAt])
}

model RepaymentInstallment {
  id     String @id @default(cuid())
  loanId String
  loan   Loan   @relation("LoanRepaymentInstallments", fields: [loanId], references: [id], onDelete: Cascade)

  installmentNumber Int
  dueDate           DateTime

  // Scheduled Amounts
  principalDue Decimal @db.Decimal(15, 2)
  interestDue  Decimal @db.Decimal(15, 2)
  penaltyDue   Decimal @default(0) @db.Decimal(15, 2) // Contingent, starts at 0
  feeDue       Decimal @default(0) @db.Decimal(15, 2) // Contingent, starts at 0

  // Paid Amounts (Mutable State)
  principalPaid Decimal @default(0) @db.Decimal(15, 2)
  interestPaid  Decimal @default(0) @db.Decimal(15, 2)
  penaltyPaid   Decimal @default(0) @db.Decimal(15, 2)
  feesPaid      Decimal @default(0) @db.Decimal(15, 2)

  isFullyPaid Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([loanId, installmentNumber])
  @@index([loanId])
  @@index([dueDate])
}

